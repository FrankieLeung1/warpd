{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug warpd (Foreground Daemon)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/warpd",
            "args": ["-f"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build warpd",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
